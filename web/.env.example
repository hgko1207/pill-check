# data.go.kr 인증키 (Encoding)
# 활용신청 4건 → 인증키 1개:
#   - 의약품 제품 허가정보 (15095677)
#   - 의약품안전사용서비스(DUR)성분정보 (15056780) — 핵심
#   - 의약품안전사용서비스(DUR)품목정보 (15059486)
#   - 건강기능식품정보 (15056760)
# 마이페이지 → "일반 인증키 (Encoding)" 그대로 복사
# 자세한 절차: docs/api-key-guide.md

VITE_NEDRUG_API_KEY=

# (선택) 식품안전나라 별도 OpenAPI — V1엔 비워둬도 OK.
# foodsafetykorea.go.kr/api 자체 포털 추가 사용 시 (V1.5+).
VITE_FOODSAFETY_API_KEY=
