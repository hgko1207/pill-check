# data.go.kr 인증키 (Encoding)
# 활용신청 4건 → 인증키 1개:
#   - 의약품 제품 허가정보 (15095677)
#   - 의약품안전사용서비스(DUR)성분정보 (15056780) — 핵심
#   - 의약품안전사용서비스(DUR)품목정보 (15059486)
#   - 건강기능식품정보 (15056760)
# 마이페이지 → "일반 인증키 (Encoding)" 그대로 복사
# 자세한 절차: docs/api-key-guide.md

VITE_NEDRUG_API_KEY=

# 식품안전나라 인증키 — 영양제(건강기능식품) 검색에 사용
# 이 키가 비어 있으면 영양제 검색이 비활성화되고 의약품만 검색됩니다.
# 발급: https://www.foodsafetykorea.go.kr/api 회원가입 → 마이페이지 → 인증키 발급 신청
# (data.go.kr과 별도 포털·별도 키)
VITE_FOODSAFETY_API_KEY=

# Google Gemini API 키 (V1.7 AI 해설 — 무료 티어 1500/일)
# 발급: https://aistudio.google.com → "Get API Key" (카드 등록 불필요)
#
# 두 가지 환경에 따라 다르게 설정:
# 1) Vercel production: 환경변수 GEMINI_API_KEY 추가 (서버측 /api/llm 사용, 클라이언트 노출 X)
# 2) 로컬 dev 직접 호출: 아래 VITE_GEMINI_API_KEY에 입력 (Vite client에 노출됨, 로컬 테스트용)
#
# Vercel만 쓸 거면 아래 VITE_ 변수는 비워두세요.
VITE_GEMINI_API_KEY=
